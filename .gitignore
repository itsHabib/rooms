/target
*.swp
.DS_Store

# IDE noise
.idea/
.vscode/
*.iml

# Built rootfs images are NOT committed (per rootfs-builder spec ED-2);
# script is the source of truth, artifact is local-only.
/images/*.ext4
/images/*.tmp
/images/*.bin

# Per-room state lives in ~/.local/state/rooms/; never end up here, but
# guard against an accidental dev redirect.
/.rooms-state/

# cargo-mutants scratch output (the scorer's mutation-audit clincher); the
# mutants CI workflow uploads it fresh, so it's never committed.
/mutants.out/
/mutants.out.old/

# Secrets — never commit
.env
.env.*
*.pem
*.key
credentials*
secrets/
