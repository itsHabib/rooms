/target
*.swp
.DS_Store

# Built rootfs images are NOT committed (per rootfs-builder spec ED-2);
# script is the source of truth, artifact is local-only.
/images/*.ext4
/images/*.tmp
/images/*.bin

# Per-room state lives in ~/.local/state/rooms/; never end up here, but
# guard against an accidental dev redirect.
/.rooms-state/
